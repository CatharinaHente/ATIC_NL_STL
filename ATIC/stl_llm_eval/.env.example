# Obtain keys from the providers and never commit the real .env file.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Current example defaults; pin/change these for the actual experiment.
OPENAI_MODEL=gpt-5.6-terra
ANTHROPIC_MODEL=claude-sonnet-5

# Local ClarifySTL bridge. Copy clarify_wrapper_template.py into your repo,
# implement its function, then point this command to it.
CLARIFY_COMMAND=python clarify_wrapper.py
CLARIFY_MODEL=clarifystl-local
